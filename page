<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Respawn News — Noticias Gaming</title>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;600&family=Share+Tech+Mono&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --cyan:   #00f5ff;
      --magenta:#ff2d78;
      --yellow: #f5e642;
      --dark:   #05060f;
      --dark2:  #0b0d1e;
      --dark3:  #111428;
      --glass:  rgba(0,245,255,0.04);
      --border: rgba(0,245,255,0.15);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      background: var(--dark);
      color: #c8d8e8;
      font-family: 'Rajdhani', sans-serif;
      font-size: 16px;
      line-height: 1.6;
      overflow-x: hidden;
    }

    /* ── SCANLINES overlay ── */
    body::before {
      content: '';
      position: fixed; inset: 0;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0,0,0,0.18) 2px,
        rgba(0,0,0,0.18) 4px
      );
      pointer-events: none;
      z-index: 9999;
    }

    /* ── NOISE grain ── */
    body::after {
      content: '';
      position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 9998;
      opacity: .4;
    }

    /* ══════════════════ NAV ══════════════════ */
    nav {
      position: sticky; top: 0; z-index: 100;
      background: rgba(5,6,15,0.85);
      backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--border);
      padding: 0 2rem;
      display: flex; align-items: center; justify-content: space-between;
      height: 64px;
    }

    .nav-logo {
      font-family: 'Orbitron', sans-serif;
      font-weight: 900;
      font-size: 1.4rem;
      letter-spacing: .1em;
      color: var(--cyan);
      text-decoration: none;
      text-shadow: 0 0 18px var(--cyan), 0 0 40px rgba(0,245,255,.3);
      position: relative;
    }
    .nav-logo span { color: var(--magenta); }

    .nav-links {
      display: flex; gap: 2rem; list-style: none;
    }
    .nav-links a {
      font-family: 'Orbitron', sans-serif;
      font-size: .7rem;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: #7a90a8;
      text-decoration: none;
      transition: color .2s;
      position: relative;
    }
    .nav-links a::after {
      content: '';
      position: absolute; bottom: -4px; left: 0; right: 0;
      height: 1px;
      background: var(--cyan);
      transform: scaleX(0);
      transition: transform .25s;
    }
    .nav-links a:hover { color: var(--cyan); }
    .nav-links a:hover::after { transform: scaleX(1); }
    .nav-links a.active { color: var(--cyan); }
    .nav-links a.active::after { transform: scaleX(1); }

    .nav-search {
      display: flex; align-items: center; gap: .5rem;
      background: var(--glass);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: .35rem .75rem;
    }
    .nav-search input {
      background: none; border: none; outline: none;
      color: #c8d8e8;
      font-family: 'Share Tech Mono', monospace;
      font-size: .8rem;
      width: 160px;
    }
    .nav-search input::placeholder { color: #3a5060; }
    .nav-search svg { color: var(--cyan); flex-shrink: 0; }

    /* ══════════════════ TICKER ══════════════════ */
    .ticker-wrap {
      background: var(--magenta);
      overflow: hidden;
      height: 30px;
      display: flex; align-items: center;
    }
    .ticker-label {
      font-family: 'Orbitron', sans-serif;
      font-size: .6rem;
      letter-spacing: .15em;
      background: #0a0010;
      color: var(--magenta);
      padding: 0 1rem;
      height: 100%;
      display: flex; align-items: center;
      flex-shrink: 0;
      white-space: nowrap;
    }
    .ticker-track {
      display: flex;
      animation: ticker 28s linear infinite;
      gap: 3rem;
      padding-left: 2rem;
    }
    .ticker-track span {
      font-family: 'Rajdhani', sans-serif;
      font-weight: 600;
      font-size: .85rem;
      color: #fff;
      white-space: nowrap;
    }
    .ticker-track span::before { content: '▶ '; font-size: .6rem; opacity: .7; }
    @keyframes ticker {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }

    /* ══════════════════ MAIN LAYOUT ══════════════════ */
    main { max-width: 1280px; margin: 0 auto; padding: 3rem 2rem 5rem; }

    /* ── Section header ── */
    .section-header {
      display: flex; align-items: center; gap: 1rem;
      margin-bottom: 1.8rem;
    }
    .section-header h2 {
      font-family: 'Orbitron', sans-serif;
      font-size: .75rem;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: var(--cyan);
    }
    .section-header::after {
      content: '';
      flex: 1;
      height: 1px;
      background: linear-gradient(90deg, var(--border) 0%, transparent 100%);
    }
    .section-header .tag {
      font-family: 'Share Tech Mono', monospace;
      font-size: .65rem;
      color: var(--magenta);
      border: 1px solid var(--magenta);
      padding: .1rem .5rem;
      border-radius: 2px;
    }

    /* ══════════════════ FEATURED ══════════════════ */
    .featured {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
      gap: 1.5rem;
      margin-bottom: 4rem;
    }

    .card {
      position: relative;
      background: var(--dark2);
      border: 1px solid var(--border);
      border-radius: 6px;
      overflow: hidden;
      cursor: pointer;
      transition: transform .25s, border-color .25s, box-shadow .25s;
      text-decoration: none;
      color: inherit;
      display: flex;
      flex-direction: column;
    }
    .card:hover {
      transform: translateY(-4px);
      border-color: var(--cyan);
      box-shadow: 0 0 24px rgba(0,245,255,.12), 0 8px 32px rgba(0,0,0,.5);
    }

    /* Featured big card */
    .card-big {
      grid-row: 1 / 3;
    }
    .card-big .card-img { height: 320px; }

    .card-img {
      width: 100%; height: 200px;
      object-fit: cover;
      display: block;
      filter: saturate(.8) brightness(.85);
      transition: filter .3s, transform .4s;
    }
    .card:hover .card-img { filter: saturate(1) brightness(1); transform: scale(1.03); }

    .card-img-wrap {
      overflow: hidden;
      position: relative;
      flex-shrink: 0;
    }
    /* image placeholder gradient */
    .card-img-placeholder {
      width: 100%;
      display: block;
      flex-shrink: 0;
    }
    .card-big .card-img-placeholder { height: 320px; }
    .card-img-placeholder { height: 200px; }

    .card-body { padding: 1.2rem 1.4rem 1.4rem; flex: 1; display: flex; flex-direction: column; gap: .6rem; }

    .badge {
      display: inline-block;
      font-family: 'Orbitron', sans-serif;
      font-size: .55rem;
      letter-spacing: .15em;
      text-transform: uppercase;
      padding: .2rem .6rem;
      border-radius: 2px;
      align-self: flex-start;
    }
    .badge-review  { background: rgba(245,230,66,.12); color: var(--yellow); border: 1px solid rgba(245,230,66,.3); }
    .badge-news    { background: rgba(0,245,255,.1);   color: var(--cyan);   border: 1px solid rgba(0,245,255,.25); }
    .badge-launch  { background: rgba(255,45,120,.12); color: var(--magenta);border: 1px solid rgba(255,45,120,.3); }
    .badge-esports { background: rgba(140,80,255,.15); color: #b87fff;       border: 1px solid rgba(140,80,255,.3); }

    .card h3 {
      font-family: 'Orbitron', sans-serif;
      font-size: 1rem;
      font-weight: 700;
      line-height: 1.35;
      color: #e8f0f8;
    }
    .card-big h3 { font-size: 1.4rem; }

    .card p {
      font-size: .9rem;
      color: #7a90a8;
      line-height: 1.55;
      flex: 1;
    }

    .card-meta {
      display: flex; align-items: center; justify-content: space-between;
      font-family: 'Share Tech Mono', monospace;
      font-size: .7rem;
      color: #3a5060;
    }
    .card-meta .author { color: var(--cyan); opacity: .7; }

    /* corner accent */
    .card::before {
      content: '';
      position: absolute; top: 0; right: 0;
      width: 0; height: 0;
      border-style: solid;
      border-width: 0 28px 28px 0;
      border-color: transparent var(--dark3) transparent transparent;
      z-index: 2;
      transition: border-color .25s;
    }
    .card:hover::before { border-color: transparent var(--cyan) transparent transparent; }

    /* score badge for reviews */
    .score {
      position: absolute; top: 12px; left: 12px; z-index: 3;
      background: rgba(5,6,15,.8);
      border: 2px solid var(--yellow);
      border-radius: 4px;
      font-family: 'Orbitron', sans-serif;
      font-weight: 900;
      font-size: 1.1rem;
      color: var(--yellow);
      width: 42px; height: 42px;
      display: flex; align-items: center; justify-content: center;
      text-shadow: 0 0 10px var(--yellow);
    }

    /* ══════════════════ NEWS GRID ══════════════════ */
    .news-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      margin-bottom: 4rem;
    }

    /* ══════════════════ LAUNCHES ══════════════════ */
    .launches-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.2rem;
    }

    .launch-card {
      background: var(--dark2);
      border: 1px solid var(--border);
      border-radius: 6px;
      overflow: hidden;
      cursor: pointer;
      transition: transform .25s, border-color .25s, box-shadow .25s;
      position: relative;
    }
    .launch-card:hover {
      transform: translateY(-4px);
      border-color: var(--magenta);
      box-shadow: 0 0 20px rgba(255,45,120,.1);
    }
    .launch-card-img {
      height: 130px;
      display: block;
      width: 100%;
    }
    .launch-card-body { padding: .9rem 1rem 1rem; }
    .launch-card h4 {
      font-family: 'Orbitron', sans-serif;
      font-size: .75rem;
      font-weight: 700;
      color: #e0eaf5;
      margin-bottom: .35rem;
      line-height: 1.3;
    }
    .launch-date {
      font-family: 'Share Tech Mono', monospace;
      font-size: .68rem;
      color: var(--magenta);
    }
    .launch-platform {
      font-family: 'Rajdhani', sans-serif;
      font-size: .8rem;
      color: #4a6070;
      margin-top: .2rem;
    }

    /* ══════════════════ PLACEHOLDER IMAGES (SVG gradients) ══════════════════ */
    /* Each card gets a unique atmospheric gradient background */

    /* ══════════════════ FOOTER ══════════════════ */
    footer {
      border-top: 1px solid var(--border);
      padding: 2rem;
      text-align: center;
      font-family: 'Share Tech Mono', monospace;
      font-size: .7rem;
      color: #2a3a4a;
    }
    footer span { color: var(--cyan); }

    /* ══════════════════ SCROLLBAR ══════════════════ */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--dark); }
    ::-webkit-scrollbar-thumb { background: #1a2a3a; border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--cyan); }

    /* ══════════════════ ANIMATIONS ══════════════════ */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .featured, .news-grid, .launches-grid {
      animation: fadeUp .6s ease both;
    }
    .news-grid { animation-delay: .15s; }
    .launches-grid { animation-delay: .3s; }

    /* ══════════════════ RESPONSIVE ══════════════════ */
    @media (max-width: 900px) {
      .featured { grid-template-columns: 1fr; }
      .card-big { grid-row: auto; }
      .card-big .card-img-placeholder { height: 240px; }
      .news-grid { grid-template-columns: 1fr 1fr; }
      .launches-grid { grid-template-columns: 1fr 1fr; }
      .nav-search { display: none; }
    }
    @media (max-width: 560px) {
      .nav-links { gap: 1rem; }
      .nav-links li:nth-child(n+4) { display: none; }
      .news-grid { grid-template-columns: 1fr; }
      .launches-grid { grid-template-columns: 1fr 1fr; }
    }
  </style>
</head>
